    <diagram id="loop-agent" name="Page-1">
        <mxGraphModel dx="832" dy="423" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- Title -->
                <mxCell id="title" value="&lt;h2 style=&quot;margin:0;font-size:20px;color:#202124;&quot;&gt;LoopAgent&lt;/h2&gt;&lt;p style=&quot;margin:4px 0 0;font-size:11px;color:#9aa0a6;&quot;&gt;quality_improvement_loop · Repeats until quality passes or max_iterations reached&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="100" y="20" width="960" height="54" as="geometry"/>
                </mxCell>

                <!-- Zone -->
                <mxCell id="zone" value="" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#174ea6;strokeWidth=1;dashed=1;dashPattern=2 2;pointerEvents=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="140" width="1000" height="340" as="geometry"/>
                </mxCell>
                <mxCell id="zone_label" value="&lt;b style=&quot;color:#174ea6;font-size:11px;&quot;&gt;quality_improvement_loop (LoopAgent · max 2 iterations)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="90" y="144" width="560" height="24" as="geometry"/>
                </mxCell>

                <!-- quality_checker as rhombus -->
                <mxCell id="checker" value="&lt;b style=&quot;color:#202124;&quot;&gt;quality_checker_agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#9aa0a6;&quot;&gt;Quality OK?&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f2124;strokeWidth=2;shadow=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="420" y="200" width="220" height="140" as="geometry"/>
                </mxCell>

                <!-- content_improver_agent -->
                <mxCell id="improver" value="&lt;b style=&quot;color:#202124;&quot;&gt;content_improver_agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#9aa0a6;&quot;&gt;sub_agent 2&lt;br/&gt;Rewrites content&lt;br/&gt;output_key: current_content&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f2124;strokeWidth=2;shadow=1;arcSize=3;fontSize=11;fontColor=#202124;" parent="1" vertex="1">
                    <mxGeometry x="160" y="210" width="200" height="120" as="geometry"/>
                </mxCell>

                <!-- Approved output -->
                <mxCell id="approved" value="&lt;b style=&quot;color:#202124;&quot;&gt;Content Approved&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;color:#9aa0a6;&quot;&gt;escalate_to_parent()&lt;/span&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fbbc04;strokeColor=#1f2124;strokeWidth=2;shadow=1;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="740" y="230" width="220" height="80" as="geometry"/>
                </mxCell>

                <!-- Arrow: checker → No → improver -->
                <mxCell id="arr_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#000000;strokeWidth=2;dashed=1;dashPattern=8 8;endArrow=open;endFill=0;fontColor=#202124;fontStyle=1;fontSize=10;" parent="1" source="checker" target="improver" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- Arrow: checker → Yes → approved -->
                <mxCell id="arr_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#000000;strokeWidth=2;dashed=1;dashPattern=8 8;endArrow=open;endFill=0;fontColor=#202124;fontStyle=1;fontSize=10;" parent="1" source="checker" target="approved" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- Arrow: improver → loop back to checker (below) -->
                <mxCell id="arr_loop" value="loop back" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#000000;strokeWidth=1;dashed=1;dashPattern=4 4;endArrow=open;endFill=0;fontColor=#202124;fontStyle=2;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="improver" target="checker" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="260" y="400"/>
                            <mxPoint x="530" y="400"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- Note -->
                <mxCell id="note" value="&lt;span style=&quot;font-size:10px;color:#9aa0a6;&quot;&gt;The checker calls escalate_to_parent() when content passes. If not, the improver rewrites and the loop repeats — up to max_iterations times.&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="80" y="520" width="1000" height="30" as="geometry"/>
                </mxCell>

            </root>
