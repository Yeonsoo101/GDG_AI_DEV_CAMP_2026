# Tavily — web search (https://tavily.com)
TAVILY_API_KEY=your-tavily-api-key-here

# Google Gemini API — agent reasoning + structured extraction
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Supabase — shortlist persistence
# Project URL: Supabase dashboard → Settings → API → Project URL
# Service key: same page → Project API keys → service_role  (NOT anon)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
